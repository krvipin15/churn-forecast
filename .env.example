# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# Check 'settings.py' for more information on the available settings and their default values.

# General
ENVIRONMENT=<your-environment>
LOG_LEVEL=<your-log-level>
LOG_BACKUP_COUNT=<your-log-backup-count>
LOG_ROTATION_WHEN=<your-log-rotation-when>
LOGGER_NAME=<your-logger-name>
PREFECT_LOGGING_EXTRA_LOGGERS=<your-logger-name>

# Sentry
SENTRY_DSN=<your-sentry-dsn>
